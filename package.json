{
  "name": "tabel",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "fst-web"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=fst-web",
    "start": "npm run dev",
    "dev:local": "concurrently -n db,web -c cyan,green \"npm run dev:db\" \"vite\"",
    "dev:db": "node server/index.mjs",
    "dev:desktop": "npm run dev:local",
    "dev:fst-web": "npm run dev",
    "cloud": "npm run dev",
    "dev:site": "npm run dev",
    "preview:site": "npm run build && npm run preview",
    "dev:site:ps1": "powershell -ExecutionPolicy Bypass -File scripts/dev-site.ps1",
    "nika:start": "powershell -ExecutionPolicy Bypass -File scripts/nika-start.ps1",
    "nika:start:ide": "powershell -ExecutionPolicy Bypass -File scripts/nika-start.ps1 -IdeOnly",
    "build": "npm run build:fst-web",
    "build:fst-web": "npm run build --workspace=fst-web",
    "build:local": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "npm run preview --workspace=fst-web",
    "setup:firebase": "powershell -ExecutionPolicy Bypass -File fst-web/scripts/setup-firebase-db.ps1",
    "sync:vercel-env": "node scripts/sync-vercel-env.mjs",
    "deploy:cloud": "node scripts/build.mjs && vercel --prod",
    "deploy": "npm run deploy:cloud",
    "deploy:firebase": "npm run deploy:hosting --workspace=fst-web",
    "release": "node scripts/build.mjs && npm run deploy:firestore-rules && vercel --prod",
    "deploy:firestore-rules": "npm run deploy:firestore-rules --workspace=fst-web",
    "migrate:local-db": "node scripts/normalize-local-db.mjs",
    "migrate:cloud-store": "npm run migrate:cloud-store --workspace=fst-web",
    "migrate:cloud-shards": "npm run migrate:cloud-shards --workspace=fst-web",
    "export:cloud-backup": "npm run export:cloud-backup --workspace=fst-web",
    "export:cloud-backup:admin": "npm run export:cloud-backup:admin --workspace=fst-web",
    "import:cloud-backup": "npm run import:cloud-backup --workspace=fst-web",
    "migrate:firebase-project": "npm run migrate:firebase-project --workspace=fst-web",
    "migrate:firebase-project:dry": "npm run migrate:firebase-project:dry --workspace=fst-web",
    "switch:firebase-project": "npm run switch:firebase-project --workspace=fst-web",
    "migrate:guided": "powershell -ExecutionPolicy Bypass -File scripts/migrate-guided.ps1",
    "migrate:login": "powershell -ExecutionPolicy Bypass -File scripts/migrate-guided.ps1 -Step Login",
    "migrate:export": "powershell -ExecutionPolicy Bypass -File scripts/migrate-export.ps1",
    "migrate:import": "powershell -ExecutionPolicy Bypass -File scripts/migrate-import.ps1",
    "migrate:deploy-target": "powershell -ExecutionPolicy Bypass -File scripts/migrate-deploy-target.ps1",
    "migrate:personal": "powershell -ExecutionPolicy Bypass -File scripts/migrate-to-personal.ps1",
    "migrate:full": "powershell -ExecutionPolicy Bypass -File scripts/migrate-full-stack.ps1",
    "firebase:login:nika": "powershell -ExecutionPolicy Bypass -File scripts/firebase-login-as.ps1 -Account nika",
    "firebase:login:admin": "powershell -ExecutionPolicy Bypass -File scripts/firebase-login-as.ps1 -Account admin",
    "vercel:login:nika": "powershell -ExecutionPolicy Bypass -File scripts/vercel-login-as.ps1",
    "migrate:vercel": "powershell -ExecutionPolicy Bypass -File scripts/migrate-vercel.ps1",
    "deploy:otgruzka": "powershell -ExecutionPolicy Bypass -File scripts/deploy-otgruzka-vercel.ps1",
    "setup:e-drive": "node scripts/setup-e-drive.mjs",
    "clear:hr-cloud": "node fst-web/scripts/clear-hr-employees.mjs",
    "clear:hr-cloud:ps1": "powershell -ExecutionPolicy Bypass -File scripts/clear-hr-cloud.ps1",
    "reset-local": "node scripts/reset-local.mjs",
    "test:firebase": "node fst-web/scripts/test-cloud-save.mjs",
    "test:e2": "node scripts/e2-journal-acceptance.mjs"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.14.5",
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "firebase": "^11.10.0",
    "firebase-admin": "^13.10.0",
    "html2canvas": "^1.4.1",
    "jsbarcode": "^3.12.3",
    "jspdf": "^4.2.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
