{
  "name": "fst-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "sync:firestore-rules": "node scripts/sync-firestore-rules.mjs",
    "deploy:firestore-rules": "node scripts/sync-firestore-rules.mjs && firebase deploy --only firestore:rules,storage --project fst-uchet-14c02",
    "deploy:hosting": "npm run build && firebase deploy --only hosting --project fst-uchet-14c02",
    "migrate:cloud-store": "node scripts/normalize-cloud-store.mjs",
    "migrate:cloud-shards": "node scripts/migrate-cloud-shards.mjs",
    "clear:hr-cloud": "node scripts/clear-hr-employees.mjs",
    "clear:hr-cloud:ps1": "powershell -ExecutionPolicy Bypass -File ../scripts/clear-hr-cloud.ps1",
    "reset-local": "node ../scripts/reset-local.mjs"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.14.5",
    "firebase": "^11.10.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12"
  }
}
